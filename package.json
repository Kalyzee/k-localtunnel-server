{
  "author": "Roman Shtylman <shtylman@gmail.com>",
  "name": "@kalyzee/k-localtunnel-server",
  "description": "A self-hosted LocalTunnel server for exposing local Node.js servers to the internet. Supports optional authentication via authKey for secure tunnels.",
  "version": "1.0.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Kalyzee/k-localtunnel-server.git"
  },
  "contributors": [
    "Roman Shtylman <shtylman@gmail.com>",
    "Dorian Rouby <dorian.rouby@kalyzee.com>"
  ],
  "type": "module",
  "dependencies": {
    "book": "1.3.3",
    "debug": "3.1.0",
    "esm": "3.0.34",
    "express": "5.2.1",
    "human-readable-ids": "1.0.3",
    "koa": "2.5.1",
    "koa-router": "7.4.0",
    "localenv": "0.2.2",
    "optimist": "0.6.1",
    "pump": "3.0.0",
    "tldjs": "2.3.1"
  },
  "devDependencies": {
    "@types/debug": "4.1.12",
    "@types/express": "5.0.6",
    "@types/node": "25.3.3",
    "@types/tldjs": "2.3.4",
    "mocha": "5.1.1",
    "node-dev": "3.1.3",
    "supertest": "3.1.0",
    "typescript": "5.9.3",
    "ws": "5.1.1"
  },
  "scripts": {
    "test": "mocha --check-leaks --require esm './**/*.test.js'",
    "start": "./bin/server",
    "dev": "node-dev bin/server --port 3000",
    "build": "yarn clean && tsc && cp -R lib dist/esm/lib",
    "clean": "rm -rf dist"
  }
}
