#!/usr/bin/env node

import 'localenv';
import optimist from 'optimist';

import log from 'book';
import Debug from 'debug';

//import CreateServer from '../server.js';
import { createTunnelInstance } from '../dist/esm/index.js'

const debug = Debug('localtunnel');


const getEnvVar = ( env, number = false) => {
    if (number) {
        let value = Number(process.env[env]);
        if (!Number.isNaN(value)) return value;
        return undefined;
    }
    return process.env[env];
}

const argv = optimist
    .usage('Usage: $0 --port [num]')
    .options('secure', {
        default: getEnvVar('SECURE') === "true",
        describe: 'use this flag to indicate proxy over https'
    })
    .options('port', {
        default:  getEnvVar('PORT') ?? '80',
        describe: 'listen on this port for outside requests'
    })
    .options('address', {
        default: getEnvVar('ADDRESS') ?? '0.0.0.0',
        describe: 'IP address to bind to'
    })
    .options('domain', {
        default: getEnvVar('DOMAIN'),
        describe: 'Specify the base domain name. This is optional if hosting localtunnel from a regular example.com domain. This is required if hosting a localtunnel server from a subdomain (i.e. lt.example.dom where clients will be client-app.lt.example.come)',
    })
    .options('landing', {
        default: getEnvVar('LANDING'),
        describe: 'Specify the landing page',
    })
    .options('auth-required', {
        default: getEnvVar('AUTH_REQUIRED') === 'true',
        describe: 'If true, clients must present a valid API key via x-lt-auth. Requires --mongo-uri.',
    })
    .options('mongo-uri', {
        default: getEnvVar('MONGO_URI'),
        describe: 'MongoDB connection string for the API key store. Required when --auth-required=true.',
    })
    .options('admin-username', {
        default: getEnvVar('ADMIN_USERNAME'),
        describe: 'Username for admin interface (Basic Auth). If not defined, no admin authentication is required.',
    })
    .options('admin-password', {
        default: getEnvVar('ADMIN_PASSWORD'),
        describe: 'Password for admin interface (Basic Auth). If not defined, no admin authentication is required.',
    })
    .options('default-filters', {
        default: getEnvVar('DEFAULT_FILTERS') ?? '[{"pattern":".*","authorized":true}]',
        describe: 'JSON array of default authorization filters. Example: \'[{"pattern":"^device-.*$","authorized":true}]\'. First match wins.',
    })
    .options('max-sockets', {
        default: getEnvVar('MAX_SOCKETS', true),
        describe: 'default maximum number of sockets per client (fallback for all types)'
    })
    .options('max-http-sockets', {
        default: getEnvVar('MAX_HTTP_SOCKETS', true),
        describe: 'maximum sockets for HTTP tunnels (defaults to max-sockets)'
    })
    .options('max-tcp-sockets', {
        default: getEnvVar('MAX_TCP_SOCKETS', true),
        describe: 'maximum sockets for TCP tunnels (defaults to max-sockets)'
    })
    .options('max-udp-sockets', {
        default: getEnvVar('MAX_UDP_SOCKETS', true),
        describe: 'maximum sockets for UDP tunnels (defaults to max-sockets)'
    })
    .options('unique-port-tcp-server', {
        default: getEnvVar('UNIQUE_PORT_TCP_SERVER', true),
        describe: 'define a unique port for tcp socket (dynamic port by default)'
    })
    .argv;


if (argv['help'] || getEnvVar('HELP') === true) {
    optimist.showHelp();
    process.exit();
}

const params = {
    max_sockets: argv['max-sockets'],
    max_http_sockets: argv['max-http-sockets'],
    max_tcp_sockets: argv['max-tcp-sockets'],
    max_udp_sockets: argv['max-udp-sockets'],
    secure: argv.secure,
    domain: argv.domain,
    landing: argv.landing,
    authRequired: argv['auth-required'],
    mongoUri: argv['mongo-uri'],
    adminUsername: argv['admin-username'],
    adminPassword: argv['admin-password'],
    defaultFilters: argv['default-filters'] ? JSON.parse(argv['default-filters']) : undefined,
    uniquePortTcpServer: argv['unique-port-tcp-server'],
};
// Don't log mongoUri directly — it may contain credentials.
debug("Server params : ", JSON.stringify({ ...params, mongoUri: params.mongoUri ? '***' : undefined }, null, 2));

const tunnelInstance = createTunnelInstance(params);
const server = tunnelInstance.server;

const port = argv['port'];
const address = argv['addresse'];
debug("Prepare server to listen on : ", port, ' / ', address);

try {
    await tunnelInstance.ready();
} catch (err) {
    log.error('Failed to initialize tunnel server:', err.message);
    process.exit(1);
}

server.listen(port, address, () => {
    debug('server listening on port: %d', server.address().port);
});

process.on('SIGINT', () => {
    process.exit();
});

process.on('SIGTERM', () => {
    process.exit();
});

process.on('uncaughtException', (err) => {
    log.error(err);
});

process.on('unhandledRejection', (reason, promise) => {
    log.error(reason);
});

// vim: ft=javascript

